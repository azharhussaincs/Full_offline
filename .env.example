# ---------------------------------------------------------------------------
# Copy this file to ".env" and adjust the values for your environment.
#   cp .env.example .env
#
# The application reads these at start-up (see app/config/settings.py).
# Never commit the real ".env" — it is listed in .gitignore.
# ---------------------------------------------------------------------------

# --- Elasticsearch connection ----------------------------------------------
ES_HOST=https://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=admin123
ES_INDEX=tc_index
# Set to "true" only if you have a valid CA / certificate configured.
ES_VERIFY_CERTS=false
# Request timeout in seconds.
ES_TIMEOUT=30

# --- Application settings ---------------------------------------------------
APP_NAME=PeopleFinder
# How many results to fetch per page (a "Load more" button fetches the next page).
APP_PAGE_SIZE=20

# --- Logging ---------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Directory (relative to project root, or absolute) for log files.
LOG_DIR=logs

# --- Search history & exports ----------------------------------------------
HISTORY_FILE=search_history.json
HISTORY_MAX=50
EXPORT_DIR=exports
